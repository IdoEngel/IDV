{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Compiler",
            "type": "shell",
            "command": "cmake --build build --clean-first",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"],
            "detail": "Build the compiler project"
        },
        {
            "label": "Clean and Build",
            "type": "shell",
            "command": "rm -rf build && cmake -B build -S . -DCMAKE_EXPORT_COMPILE_COMMANDS=ON && cmake --build build",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Clean and rebuild the entire project"
        },
        {
            "label": "Build and Run",
            "type": "shell",
            "command": "cmake --build build && ./build/IDV",
            "group": "build",
            "problemMatcher": ["$gcc"],
            "detail": "Build and run the compiler in one step"
        }
    ]
}